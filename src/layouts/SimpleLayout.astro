---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'エドナ屋 | EDNAYA',
  description = 'エドナ屋のアーティストページ',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-black text-white">
    <header class="fixed top-0 left-0 right-0 z-40 bg-black/70 backdrop-blur border-b border-stone-800">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-center">
        <a href={`${base}edna-books`} class="inline-block">
          <img src={`${base}images/logo/ednabooks_logo.svg`} alt="EDNA BOOKS" class="h-10 w-auto" />
        </a>
      </div>
    </header>

    <main class="pt-16">
      <slot />
    </main>
  </body>
</html>
