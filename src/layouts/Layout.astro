---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  brandColor?: string;
}

const {
  title = 'エドナ屋 | EDNAYA',
  description = 'EDNA、BIRDIE、PLANET FOTO LABOR、STUDIO LEON、EDNA BOOKS — エドナ屋のポータルサイト。',
  image = '/images/heroes/edna006.jpg',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonicalURL = Astro.url;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="ja" />
    <meta name="author" content="エドナ屋" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "エドナ屋",
      "url": "https://edna.jp",
      "description": description,
      "image": image,
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "JP",
        "addressLocality": "藤沢市",
        "addressRegion": "神奈川県",
        "postalCode": "251-0021",
        "streetAddress": "本町3-11-12"
      },
      "areaServed": "JP",
      "availableLanguage": "ja",
      "knowsLanguage": "ja"
    })} />
  </head>
  <body class="bg-stone-950 text-stone-200 font-sans antialiased">
    <header class="fixed top-0 left-0 right-0 z-50 bg-stone-950/70 backdrop-blur-md border-b border-stone-800">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={base} class="flex items-center gap-3">
          <img src={`${base}images/logo/ednaya-white.svg`} alt="エドナ屋" class="h-7 w-auto" />
          <span class="hidden sm:inline text-stone-500 font-light text-xs tracking-[0.25em]">EDNA-YA</span>
        </a>
        <nav class="hidden md:flex gap-6 text-xs tracking-[0.2em] text-stone-300">
          <a href={`${base}edna`} class="hover:text-amber-400 transition ">EDNA</a>
          <a href={`${base}birdie`} class="hover:text-emerald-400 transition">BIRDIE</a>
          <a href={`${base}planet-foto-labo`} class="hover:text-sky-400 transition">PLANET FOTO LABOR</a>
          <a href={`${base}studio-leon`} class="hover:text-[#0694e9] transition">STUDIO・LEON</a>
          <a href={`${base}edna-books`} class="hover:text-rose-400 transition">BOOKS</a>
        </nav>
        <button id="menu-button" class="md:hidden flex flex-col gap-1 group" aria-label="メニュー" aria-expanded="false">
          <span class="w-6 h-0.5 bg-stone-300 group-hover:bg-stone-100 transition"></span>
          <span class="w-6 h-0.5 bg-stone-300 group-hover:bg-stone-100 transition"></span>
          <span class="w-6 h-0.5 bg-stone-300 group-hover:bg-stone-100 transition"></span>
        </button>
      </div>
      <nav id="mobile-menu" class="md:hidden bg-stone-950/95 backdrop-blur-md border-t border-stone-800 overflow-hidden max-h-0 opacity-0 transition-all duration-300 ease-out">
        <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4 text-sm tracking-[0.2em] text-stone-300">
          <a href={`${base}edna`} class="hover:text-amber-400 transition py-2">EDNA</a>
          <a href={`${base}birdie`} class="hover:text-emerald-400 transition py-2">BIRDIE</a>
          <a href={`${base}planet-foto-labo`} class="hover:text-sky-400 transition py-2">PLANET FOTO LABOR</a>
          <a href={`${base}studio-leon`} class="hover:text-[#0694e9] transition py-2">STUDIO・LEON</a>
          <a href={`${base}edna-books`} class="hover:text-rose-400 transition py-2">BOOKS</a>
        </div>
      </nav>
    </header>

    <script>
      const menuButton = document.getElementById('menu-button');
      const mobileMenu = document.getElementById('mobile-menu');

      if (menuButton && mobileMenu) {
        menuButton.addEventListener('click', () => {
          const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
          menuButton.setAttribute('aria-expanded', String(!isExpanded));

          if (isExpanded) {
            mobileMenu.classList.remove('max-h-96', 'opacity-100');
            mobileMenu.classList.add('max-h-0', 'opacity-0');
          } else {
            mobileMenu.classList.remove('max-h-0', 'opacity-0');
            mobileMenu.classList.add('max-h-96', 'opacity-100');
          }
        });

        const links = mobileMenu.querySelectorAll('a');
        links.forEach(link => {
          link.addEventListener('click', () => {
            menuButton.setAttribute('aria-expanded', 'false');
            mobileMenu.classList.remove('max-h-96', 'opacity-100');
            mobileMenu.classList.add('max-h-0', 'opacity-0');
          });
        });
      }
    </script>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="bg-black text-stone-400 mt-2 border-t border-stone-900">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid md:grid-cols-2 gap-8 mb-8">
          <div>
            <p class="text-xl tracking-[0.3em] font-light mb-2">エドナ屋</p>
            <p class="text-xs tracking-wider text-stone-500">EDNA-YA</p>
          </div>
          <div>
            <p class="text-xs tracking-[0.3em] text-stone-400 mb-4">ELEMENTS</p>
            <ul class="space-y-1 text-sm ">
              <li><a href={`${base}edna`} class="hover:text-amber-400 transition">EDNA — Surfboards</a></li>
              <li><a href={`${base}birdie`} class="hover:text-emerald-400 transition">BIRDIE — Botanical</a></li>
              <li><a href={`${base}planet-foto-labo`} class="hover:text-sky-400 transition">PLANET FOTO LABOR</a></li>
              <li><a href={`${base}studio-leon`} class="hover:text-[#0694e9] transition">STUDIO・LEON — Architecture</a></li>
              <li><a href={`${base}edna-books`} class="hover:text-rose-400 transition">EDNA BOOKS — Art Books</a></li>
            </ul>
          </div>
        </div>
        <div class="pt-8 border-t border-stone-800 text-center text-xs text-stone-600">
          &copy; 2026 エドナ屋. All rights reserved.
        </div>
      </div>
    </footer>
  </body>
</html>
