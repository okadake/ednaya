---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const brands = [
  {
    slug: 'edna',
    name: 'EDNA',
    tagline: 'SURFBOARDS',
    description: 'サーフボードの製造・販売。波と共に生きる人々のための、こだわりの一本。',
    accent: 'from-amber-100 to-orange-50',
    text: 'text-amber-900',
    hover: 'hover:text-amber-700',
  },
  {
    slug: 'birdie',
    name: 'BIRDIE',
    tagline: 'BOTANICAL DESIGN',
    description: 'エアプランツ、多肉植物、観葉植物。日々の暮らしに、緑のいろどりを。',
    accent: 'from-emerald-100 to-green-50',
    text: 'text-emerald-900',
    hover: 'hover:text-emerald-700',
  },
  {
    slug: 'planet-foto-labo',
    name: 'PLANET FOTO LABO',
    tagline: "PHOTOGRAPHER'S ATELIER",
    description: '写真家のアトリエ。光と時間を捉えた、一枚の物語。',
    accent: 'from-sky-100 to-slate-50',
    text: 'text-sky-900',
    hover: 'hover:text-sky-700',
  },
  {
    slug: 'edna-books',
    name: 'EDNA BOOKS',
    tagline: 'ART BOOKS',
    description: 'アートブック専門店。ページの中に広がる、もうひとつの世界。',
    accent: 'from-rose-100 to-pink-50',
    text: 'text-rose-900',
    hover: 'hover:text-rose-700',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="relative min-h-[calc(100vh-4rem)] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-stone-100 via-amber-50 to-emerald-50"></div>
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-stone-500 mb-8">A HOUSE OF FOUR BRANDS</p>
      <h1 class="text-6xl md:text-8xl font-light tracking-[0.2em] mb-2 text-stone-900">
        エドナ屋
      </h1>
      <p class="text-sm tracking-[0.4em] text-stone-500 mb-12">EDNAYA</p>
      <p class="text-sm md:text-base text-stone-600 leading-loose max-w-xl mx-auto">
        サーフボード、植物、写真、本。<br />
        異なる4つの世界が集う場所。
      </p>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-xs tracking-[0.3em] text-stone-400">
      ↓ SCROLL
    </div>
  </section>

  <!-- Brands Grid -->
  <section id="brands" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-stone-500 mb-4">OUR BRANDS</p>
        <h2 class="text-3xl font-light tracking-wider">4つのブランド</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {brands.map((b) => (
          <a
            href={`${base}/${b.slug}`}
            class={`group relative block overflow-hidden bg-gradient-to-br ${b.accent} aspect-[4/3] p-10 transition-transform hover:scale-[1.01]`}
          >
            <div class="flex flex-col h-full justify-between">
              <div>
                <p class={`text-xs tracking-[0.3em] ${b.text} opacity-60 mb-3`}>{b.tagline}</p>
                <h3 class={`text-3xl md:text-4xl font-light tracking-[0.15em] ${b.text}`}>
                  {b.name}
                </h3>
              </div>
              <div>
                <p class={`text-sm ${b.text} opacity-80 leading-loose mb-6 max-w-md`}>
                  {b.description}
                </p>
                <span class={`inline-flex items-center gap-2 text-xs tracking-[0.3em] ${b.text} ${b.hover} transition`}>
                  EXPLORE
                  <span class="transition-transform group-hover:translate-x-1">→</span>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-24 px-6 bg-stone-100">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] text-stone-500 mb-4">ABOUT</p>
      <h2 class="text-3xl font-light tracking-wider mb-12">エドナ屋について</h2>
      <p class="text-stone-600 leading-loose">
        「エドナ屋」は、サーフボードの<strong class="font-medium">EDNA</strong>、植物の<strong class="font-medium">BIRDIE</strong>、<br />
        写真家のアトリエ<strong class="font-medium">PLANET FOTO LABO</strong>、<br />
        アートブックの<strong class="font-medium">EDNA BOOKS</strong>、<br />
        4つのブランドを束ねるプラットフォームです。
      </p>
      <p class="text-stone-600 leading-loose mt-6">
        それぞれが独立した世界を持ちながら、<br />
        日々の暮らしに彩りを添えるものを届けます。
      </p>
    </div>
  </section>
</Layout>
