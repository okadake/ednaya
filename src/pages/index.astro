---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const brands = [
  {
    slug: 'edna',
    name: 'EDNA',
    tagline: 'SURFBOARDS',
    description: 'サーフボードの製造・販売、波と共に生きる人々のために',
    image: 'edna007.jpg',
    logo: 'edna-white.svg',
    accent: 'text-amber-300',
    border: 'hover:border-amber-400',
  },
  {
    slug: 'birdie',
    name: 'BIRDIE',
    tagline: 'BOTANICAL DESIGN',
    description: '日々の暮らしに、緑のいろどりを',
    image: 'birdie.jpg',
    logo: 'birdie_logo.svg',
    accent: 'text-emerald-300',
    border: 'hover:border-emerald-400',
  },
  {
    slug: 'planet-foto-labo',
    name: 'PLANET FOTO LABO',
    tagline: "PHOTOGRAPHER'S ATELIER",
    description: '写真家のアトリエ、光と時間を捉えた、一枚の物語',
    image: 'planet-foto-labo03.jpg',
    logo: 'pfl-white.svg',
    accent: 'text-sky-300',
    border: 'hover:border-sky-400',
  },
  {
    slug: 'edna-books',
    name: 'EDNA BOOKS',
    tagline: 'ART BOOKS',
    description: 'アートブック専門店、ページの中に広がる、もうひとつの世界',
    image: 'ednabooks.jpg',
    logo: 'ednabooks_logo.svg',
    accent: 'text-rose-300',
    border: 'hover:border-rose-400',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="relative min-h-[calc(100vh-4rem)] flex items-center justify-center overflow-hidden -mt-16 pt-16">
    <div class="absolute inset-0">
      <img
        src={`${base}/images/heroes/edna006.jpg`}
        alt="エドナ屋"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-linear-to-b from-stone-950/80 via-stone-950/60 to-stone-950"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-stone-300 mb-2">Where worlds collide</p>
      <h1 class="mb-4 flex justify-center">
        <img
          src={`${base}/images/logo/ednaya-white.svg`}
          alt="エドナ屋"
          class="h-36 md:h-36 w-auto"
        />
      </h1>
      <p class="text-sm tracking-[0.4em] text-stone-400 mb-4">EDNA-YA</p>
      <p class="text-sm md:text-base text-stone-300 leading-loose max-w-xl mx-auto">
        サーフボード、植物、写真、本<br />
        異なる世界が集う場所
      </p>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-xs tracking-[0.3em] text-stone-500">
      ↓ SCROLL
    </div>
  </section>

  <!-- Brands Grid -->
  <section id="brands" class="py-12 px-6 bg-stone-950">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <!-- <p class="text-xs tracking-[0.4em] text-stone-500 mb-4">OUR ELEMENTS</p> -->
        <h2 class="text-3xl font-light tracking-wider text-stone-400">OUR ELEMENTS</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {brands.map((b) => (
          <a
            href={`${base}/${b.slug}`}
            class={`group relative block overflow-hidden aspect-4/3 border border-stone-800 ${b.border} transition`}
          >
            <img
              src={`${base}/images/heroes/${b.image}`}
              alt={b.name}
              class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700"
            />
            <div class="absolute inset-0 bg-linear-to-t from-stone-950 via-stone-950/40 to-stone-950/20"></div>
            <p class={`absolute top-8 left-10 z-10 text-xs tracking-[0.3em] ${b.accent}`}>{b.tagline}</p>
            <div class="absolute inset-0 z-10 flex items-center justify-center px-10">
              <div class="-mt-20 md:-mt-16">
                {b.logo ? (
                  <img
                    src={`${base}/images/logo/${b.logo}`}
                    alt={b.name}
                    class="h-20 md:h-28 w-auto max-w-full"
                  />
                ) : (
                  <h3 class="text-4xl md:text-6xl font-light tracking-[0.15em] text-white text-center">
                    {b.name}
                  </h3>
                )}
              </div>
            </div>
            <div class="absolute bottom-8 left-10 right-10 z-10">
              <p class="text-sm text-stone-300 leading-6 mb-4 max-w-md">
                {b.description}
              </p>
              <span class={`inline-flex items-center gap-2 text-xs tracking-[0.3em] ${b.accent}`}>
                EXPLORE
                <span class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-12 px-6 bg-black">
    <div class="max-w-3xl mx-auto text-center">
      <!-- <p class="text-xs tracking-[0.4em] text-stone-500 mb-4">ABOUT</p> -->
      <h2 class="text-3xl font-light tracking-wider mb-12 text-stone-400">ABOUT</h2>
      <p class="text-stone-400 leading-loose">
        「エドナ屋」は、サーフボードの<strong class="font-medium text-stone-200">EDNA</strong>、植物の<strong class="font-medium text-stone-200">BIRDIE</strong>、<br />
        写真家のアトリエ<strong class="font-medium text-stone-200">PLANET FOTO LABO</strong>、<br />
        アートブックの<strong class="font-medium text-stone-200">EDNA BOOKS</strong>、<br />
        4つのブランドを束ねるプラットフォームです。
      </p>
      <p class="text-stone-400 leading-loose mt-6">
        それぞれが独立した世界を持ちながら、<br />
        日々の暮らしに彩りを添えるものを届けます。
      </p>
    </div>
  </section>

  <!-- Access -->
  <section id="access" class="py-24 px-6 bg-stone-950">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] text-stone-500 mb-4">ACCESS</p>
      <h2 class="text-3xl font-light tracking-wider mb-4 text-white">アクセス</h2>
      <p class="text-stone-400 text-sm tracking-wider mb-10">神奈川県藤沢市本町3-11-12</p>
      <div class="w-full aspect-video overflow-hidden border border-stone-800">
        <iframe
          src="https://maps.google.com/maps?q=神奈川県藤沢市本町3-11-12&output=embed&hl=ja"
          style="filter: grayscale(100%);"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="エドナ屋 アクセスマップ"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
