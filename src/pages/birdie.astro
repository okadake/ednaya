---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="BIRDIE | エドナ屋" description="BIRDIE — 植物販売。">
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center justify-center bg-gradient-to-br from-emerald-100 via-green-50 to-stone-50 overflow-hidden">
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-emerald-700 mb-6">EDNAYA / 02</p>
      <h1 class="text-6xl md:text-8xl font-light tracking-[0.2em] text-emerald-900 mb-4">BIRDIE</h1>
      <p class="text-sm tracking-[0.3em] text-emerald-700">BOTANICAL DESIGN</p>
    </div>
  </section>

  <!-- About -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] text-emerald-700 mb-4">ABOUT</p>
      <h2 class="text-3xl font-light tracking-wider mb-12">BIRDIEについて</h2>
      <p class="text-stone-600 leading-loose">
        植物のある暮らしを、もっと身近に。<br />
        エアプランツ、サボテン、多肉植物、観葉植物、ドライフラワー、<br />
        日々を彩るボタニカルアイテムをお届けします。
      </p>
    </div>
  </section>

  <!-- Products -->
  <section class="py-24 px-6 bg-emerald-50/50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-emerald-700 mb-4">PRODUCTS</p>
        <h2 class="text-3xl font-light tracking-wider">取扱植物</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        {[
          'エアプランツ',
          'サボテン',
          '多肉植物',
          '観葉植物',
          'ドライフラワー',
          'アート作品',
        ].map((p) => (
          <div class="bg-white aspect-square flex items-center justify-center border border-emerald-100">
            <div class="text-center">
              <p class="text-xs tracking-[0.3em] text-stone-300 mb-3">PHOTO</p>
              <p class="text-sm tracking-wider text-emerald-900">{p}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Link -->
  <section class="py-24 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] text-emerald-700 mb-4">ONLINE STORE</p>
      <h2 class="text-3xl font-light tracking-wider mb-8">オンラインストア</h2>
      <p class="text-stone-600 leading-loose mb-8">
        商品の購入はオンラインストアから。
      </p>
      <a
        href="https://birdie-botanical.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-10 py-3 border border-emerald-700 text-emerald-700 text-sm tracking-[0.2em] hover:bg-emerald-700 hover:text-white transition"
      >
        VISIT BIRDIE BOTANICAL
      </a>
    </div>
  </section>

  <div class="text-center py-12">
    <a href={base} class="text-xs tracking-[0.3em] text-stone-500 hover:text-emerald-700 transition">
      ← BACK TO エドナ屋
    </a>
  </div>
</Layout>
