---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="BIRDIE | エドナ屋" description="BIRDIE — 植物販売。">
  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden -mt-16 pt-16">
    <div class="absolute inset-0">
      <img
        src={`${base}/images/heroes/birdie.jpg`}
        alt="BIRDIE"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-stone-950/60"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-emerald-300 mb-6">EDNAYA / 02</p>
      <h1 class="text-6xl md:text-8xl font-light tracking-[0.2em] text-white mb-4">BIRDIE</h1>
      <p class="text-sm tracking-[0.3em] text-stone-300">BOTANICAL DESIGN</p>
    </div>
  </section>

  <!-- About -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] text-emerald-400 mb-4">ABOUT</p>
      <h2 class="text-3xl font-light tracking-wider text-white mb-12">BIRDIEについて</h2>
      <p class="text-stone-400 leading-loose">
        植物のある暮らしを、もっと身近に。<br />
        エアプランツ、サボテン、多肉植物、観葉植物、ドライフラワー、<br />
        日々を彩るボタニカルアイテムをお届けします。
      </p>
    </div>
  </section>

  <!-- Products -->
  <section class="py-24 px-6 bg-black">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-emerald-400 mb-4">PRODUCTS</p>
        <h2 class="text-3xl font-light tracking-wider text-white">取扱植物</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        {[
          'エアプランツ',
          'サボテン',
          '多肉植物',
          '観葉植物',
          'ドライフラワー',
          'アート作品',
        ].map((p) => (
          <div class="bg-stone-900 aspect-square flex items-center justify-center border border-stone-800 hover:border-emerald-400 transition">
            <div class="text-center">
              <p class="text-xs tracking-[0.3em] text-stone-600 mb-3">PHOTO</p>
              <p class="text-sm tracking-wider text-emerald-300">{p}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Link -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] text-emerald-400 mb-4">ONLINE STORE</p>
      <h2 class="text-3xl font-light tracking-wider text-white mb-8">オンラインストア</h2>
      <p class="text-stone-400 leading-loose mb-8">
        商品の購入はオンラインストアから。
      </p>
      <a
        href="https://birdie-botanical.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-10 py-3 border border-emerald-400 text-emerald-300 text-sm tracking-[0.2em] hover:bg-emerald-400 hover:text-stone-950 transition"
      >
        VISIT BIRDIE BOTANICAL
      </a>
    </div>
  </section>

  <div class="text-center py-12 bg-stone-950">
    <a href={base} class="text-xs tracking-[0.3em] text-stone-500 hover:text-emerald-400 transition">
      ← BACK TO エドナ屋
    </a>
  </div>
</Layout>
