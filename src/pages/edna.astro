---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const res = await fetch('https://edna.microcms.io/api/v1/surfboards?limit=100', {
  headers: { 'X-MICROCMS-API-KEY': import.meta.env.MICROCMS_API_KEY ?? '' },
});
const data = await res.json();
const allItems = data.contents ?? [];

// カテゴリの値を取得（配列、文字列、オブジェクトに対応）
const hasCategory = (item: any, targetCategory: string): boolean => {
  // カテゴリが未設定またはダブるはい場合はデフォルトで 'Surfboards'
  if (!item.category || (Array.isArray(item.category) && item.category.length === 0)) {
    return targetCategory === 'Surfboards';
  }

  // 配列の場合
  if (Array.isArray(item.category)) {
    return item.category.some((cat: any) => {
      if (typeof cat === 'string') return cat === targetCategory;
      if (typeof cat === 'object' && cat.name) return cat.name === targetCategory;
      return false;
    });
  }

  // 文字列の場合
  if (typeof item.category === 'string') return item.category === targetCategory;

  // オブジェクトの場合
  if (typeof item.category === 'object' && item.category.name) {
    return item.category.name === targetCategory;
  }

  return false;
};

// カテゴリごとにグループ分け
const boardItems = allItems.filter((item: any) => hasCategory(item, 'Surfboards'));
const tshirtItems = allItems.filter((item: any) => hasCategory(item, 'Tshirt'));
const resinworksItems = allItems.filter((item: any) => hasCategory(item, 'ResinWorks'));
---

<Layout title="EDNA | エドナ屋" description="EDNA — サーフボードの製造・販売。">
  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden -mt-16 pt-16">
    <div class="absolute inset-0">
      <img
        src={`${base}/images/heroes/edna007.jpg`}
        alt="EDNA"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-stone-950/60"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-amber-300 mb-6">SURFBOARDS</p>
      <h1 class="mb-6 flex justify-center">
        <img
          src={`${base}/images/logo/edna-white.svg`}
          alt="EDNA"
          class="h-24 md:h-36 w-auto"
        />
      </h1>
      <!-- <p class="text-sm tracking-[0.3em] text-stone-300">SURFBOARDS</p> -->
    </div>
  </section>

  <!-- About -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="text-left md:text-center mb-8">
      <!-- <p class="text-xs tracking-[0.4em] text-amber-400 mb-4">ABOUT</p> -->
      <h2 class="text-3xl font-light tracking-wider text-amber-400 mb-12 text-center ">ABOUT</h2>
      <p class="text-stone-400 leading-loose">
        EDNAは、波と共に生きる人々のためのサーフボードブランドです。<br />
        Long Board、Short Board、Alternative —<br />
        ライダーのスタイルに合わせた一本を、職人の手でお届けします。
      </p>
      <a
        href="https://www.instagram.com/ednasurfboards/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 mt-10 text-stone-400 hover:text-amber-300 transition-colors"
        aria-label="Instagram"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
        <span class="text-xs tracking-[0.2em]">@ednasurfboards</span>
      </a>
    </div>
  </section>

  <!-- Boards Gallery -->
  <section class="py-24 px-6 bg-black">
    <div class="max-w-6xl mx-auto">
      {/* BOARDS Section */}
      {boardItems.length > 0 && (
        <div class="mb-24">
          <div class="text-center mb-16">
            <h2 class="text-3xl font-light tracking-wider text-amber-400">BOARDS</h2>
          </div>
          <div class="grid md:grid-cols-3 gap-4">
            {boardItems.map((b: any) => (
              <div
                class="border border-stone-800 cursor-pointer"
                data-lightbox={b.image?.url}
                data-name={b.name}
                data-length={b.size}
                data-caption={b.description}
              >
                <div class="overflow-hidden">
                  <img
                    src={b.image?.url}
                    alt={b.name || 'EDNA Surfboard'}
                    class="w-full object-cover hover:opacity-80 transition-opacity duration-300"
                  />
                </div>
                {b.name && (
                  <p class="text-xs tracking-[0.2em] text-stone-300 text-center py-3 px-4">{b.name}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* T-Shirt Section */}
      {tshirtItems.length > 0 && (
        <div class="mb-24">
          <div class="text-center mb-16">
            <h2 class="text-3xl font-light tracking-wider text-amber-400">T-SHIRT</h2>
          </div>
          <div class="grid md:grid-cols-3 gap-4">
            {tshirtItems.map((b: any) => (
              <div
                class="border border-stone-800 cursor-pointer"
                data-lightbox={b.image?.url}
                data-name={b.name}
                data-length={b.size}
                data-caption={b.description}
              >
                <div class="overflow-hidden">
                  <img
                    src={b.image?.url}
                    alt={b.name || 'EDNA T-Shirt'}
                    class="w-full object-cover hover:opacity-80 transition-opacity duration-300"
                  />
                </div>
                {b.name && (
                  <p class="text-xs tracking-[0.2em] text-stone-300 text-center py-3 px-4">{b.name}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Resin-works Section */}
      {resinworksItems.length > 0 && (
        <div>
          <div class="text-center mb-16">
            <h2 class="text-3xl font-light tracking-wider text-amber-400">Resin-works</h2>
          </div>
          <div class="grid md:grid-cols-3 gap-4">
            {resinworksItems.map((b: any) => (
              <div
                class="border border-stone-800 cursor-pointer"
                data-lightbox={b.image?.url}
                data-name={b.name}
                data-length={b.size}
                data-caption={b.description}
              >
                <div class="overflow-hidden">
                  <img
                    src={b.image?.url}
                    alt={b.name || 'EDNA Resin-works'}
                    class="w-full object-cover hover:opacity-80 transition-opacity duration-300"
                  />
                </div>
                {b.name && (
                  <p class="text-xs tracking-[0.2em] text-stone-300 text-center py-3 px-4">{b.name}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden flex-col items-center justify-center bg-black/90" role="dialog" aria-modal="true">
    <!-- Caption (top) -->
    <div id="lightbox-caption" class="w-full max-w-3xl px-8 pb-6 text-center">
      <p id="lightbox-name" class="text-base tracking-[0.2em] text-white mb-1"></p>
      <p id="lightbox-length" class="text-xs tracking-[0.15em] text-amber-300 mb-1"></p>
      <p id="lightbox-note" class="text-xs text-stone-400"></p>
    </div>
    <!-- Image + arrows -->
    <div class="relative flex items-center justify-center w-full">
      <button id="lightbox-prev" class="absolute left-4 text-white text-5xl leading-none hover:text-amber-300 transition-colors px-4 py-6 z-10" aria-label="前へ">‹</button>
      <img id="lightbox-img" src="" alt="EDNA Surfboard" class="max-h-[75vh] max-w-[80vw] object-contain select-none" />
      <button id="lightbox-next" class="absolute right-4 text-white text-5xl leading-none hover:text-amber-300 transition-colors px-4 py-6 z-10" aria-label="次へ">›</button>
    </div>
    <button id="lightbox-close" class="absolute top-6 right-6 text-white text-3xl leading-none hover:text-amber-300 transition-colors z-10" aria-label="閉じる">✕</button>
  </div>

  <script>
    const lightbox = document.getElementById('lightbox')!;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxName = document.getElementById('lightbox-name')!;
    const lightboxLength = document.getElementById('lightbox-length')!;
    const lightboxNote = document.getElementById('lightbox-note')!;
    const items = Array.from(document.querySelectorAll('[data-lightbox]')) as HTMLElement[];
    let currentIndex = 0;

    function showImage(index: number) {
      currentIndex = (index + items.length) % items.length;
      const d = items[currentIndex].dataset;
      lightboxImg.src = d.lightbox!;
      lightboxName.textContent = d.name || '';
      lightboxLength.textContent = d.length || '';
      lightboxNote.textContent = d.caption || '';
    }

    function openLightbox(index: number) {
      showImage(index);
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      lightboxImg.src = '';
      document.body.style.overflow = '';
    }

    items.forEach((el, i) => el.addEventListener('click', () => openLightbox(i)));

    document.getElementById('lightbox-prev')!.addEventListener('click', (e) => { e.stopPropagation(); showImage(currentIndex - 1); });
    document.getElementById('lightbox-next')!.addEventListener('click', (e) => { e.stopPropagation(); showImage(currentIndex + 1); });
    document.getElementById('lightbox-close')!.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('flex')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showImage(currentIndex - 1);
      if (e.key === 'ArrowRight') showImage(currentIndex + 1);
    });
  </script>

  <!-- Artworks -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <!-- <p class="text-xs tracking-[0.4em] text-amber-400 mb-4">ARTWORKS</p> -->
        <h2 class="text-3xl font-light tracking-wider text-amber-400">ARTWORKS</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        {['mb001.png', 'mb002.png', 'mb003.png', 'mb004.jpg', 'mb005.png'].map((img) => (
          <div class="aspect-2/3 overflow-hidden bg-stone-900 border border-stone-800 hover:border-amber-400 transition">
            <img
              src={`${base}/images/artworks/${img}`}
              alt="EDNA Artwork"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stores -->
  <section class="py-24 px-6 bg-black">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <!-- <p class="text-xs tracking-[0.4em] text-amber-400 mb-4">STORE LIST</p> -->
        <h2 class="text-3xl font-light tracking-wider text-amber-400">STORE LIST</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            name: 'EDNA屋',
            area: 'HEAD STORE',
            zip: '〒251-0037',
            address: '神奈川県藤沢市本町3-11-12',
            tel: '0466-63-8107',
            image: 'ednaya.jpg',
          },
          {
            name: 'T-STICK surfshop',
            area: 'PARTNER',
            zip: '〒251-0037',
            address: '神奈川県藤沢市鵠沼海岸2-15-150',
            tel: '0466-36-0324',
            telLabel: 'TEL',
            url: 'http://www.t-sticksurf.com/',
            image: 'tstick02.jpg',
          },
          {
            name: '3939 -SAKUSAKU-',
            area: 'PARTNER',
            zip: '〒462-0837',
            address: '愛知県名古屋北区大杉1丁目10-20',
            tel: '052-938-8222',
            telLabel: 'TEL',
            url: 'https://3939.nagoya/pages/shop',
            image: '3939.jpg',
          },
        ].map((s) => (
          <div class="group border border-stone-800 hover:border-amber-400 transition overflow-hidden">
            <div class="aspect-video overflow-hidden bg-stone-900">
              <img
                src={`${base}/images/stores/${s.image}`}
                alt={s.name}
                class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
              />
            </div>
            <div class="p-6">
              <p class="text-xs tracking-[0.3em] text-amber-400 mb-2">{s.area}</p>
              <h3 class="text-lg tracking-wider text-white mb-4">{s.name}</h3>
              <dl class="space-y-2 text-xs text-stone-400 leading-relaxed">
                <div class="flex gap-3">
                  <dt class="shrink-0 text-stone-600 w-12 tracking-wider">ADDR</dt>
                  <dd>
                    {s.zip}<br />
                    {s.address}
                  </dd>
                </div>
                <div class="flex gap-3">
                  <dt class="shrink-0 text-stone-600 w-12 tracking-wider">{s.telLabel ?? 'TEL'}</dt>
                  <dd>
                    <a href={`tel:${s.tel.replace(/-/g, '')}`} class="hover:text-amber-300 transition">{s.tel}</a>
                  </dd>
                </div>
                {s.url && (
                  <div class="flex gap-3">
                    <dt class="shrink-0 text-stone-600 w-12 tracking-wider">WEB</dt>
                    <dd>
                      <a href={s.url} target="_blank" rel="noopener noreferrer" class="hover:text-amber-300 transition break-all">
                        {s.url.replace(/^https?:\/\//, '').replace(/\/$/, '')} ↗
                      </a>
                    </dd>
                  </div>
                )}
              </dl>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="text-center py-12 bg-stone-950">
    <a href={base} class="text-xs tracking-[0.3em] text-stone-500 hover:text-amber-400 transition">
      ← BACK TO エドナ屋
    </a>
  </div>
</Layout>
