---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="EDNA | エドナ屋" description="EDNA — サーフボードの製造・販売。">
  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center justify-center bg-gradient-to-br from-amber-100 via-orange-50 to-stone-50 overflow-hidden">
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-amber-700 mb-6">EDNAYA / 01</p>
      <h1 class="text-6xl md:text-8xl font-light tracking-[0.2em] text-amber-900 mb-4">EDNA</h1>
      <p class="text-sm tracking-[0.3em] text-amber-700">SURFBOARDS</p>
    </div>
  </section>

  <!-- About -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] text-amber-700 mb-4">ABOUT</p>
      <h2 class="text-3xl font-light tracking-wider mb-12">EDNAについて</h2>
      <p class="text-stone-600 leading-loose">
        EDNAは、波と共に生きる人々のためのサーフボードブランドです。<br />
        Long Board、Short Board、Alternative —<br />
        ライダーのスタイルに合わせた一本を、職人の手でお届けします。
      </p>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-24 px-6 bg-stone-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-amber-700 mb-4">CATEGORIES</p>
        <h2 class="text-3xl font-light tracking-wider">サーフボード</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { name: 'LONG BOARD', desc: 'ゆったりとした波に寄り添う、伝統的な一本。' },
          { name: 'SHORT BOARD', desc: '機敏な動きを可能にする、現代的なデザイン。' },
          { name: 'ALTERNATIVE', desc: '型にはまらない、自由な発想のシェイプ。' },
        ].map((c) => (
          <div class="bg-white aspect-[3/4] p-8 flex flex-col justify-between border border-stone-200">
            <div class="flex-1 flex items-center justify-center">
              <span class="text-xs tracking-[0.3em] text-stone-300">PHOTO</span>
            </div>
            <div>
              <h3 class="text-sm tracking-[0.25em] text-amber-900 mb-3">{c.name}</h3>
              <p class="text-xs text-stone-500 leading-relaxed">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stores -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-amber-700 mb-4">STORE LIST</p>
        <h2 class="text-3xl font-light tracking-wider">取扱店舗</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { name: 'EDNA屋', area: 'HEAD STORE' },
          { name: 'T-STICK surfshop', area: 'PARTNER' },
          { name: 'INDY SURF', area: 'PARTNER' },
          { name: 'GOLGODA', area: 'PARTNER' },
        ].map((s) => (
          <div class="border border-stone-200 p-6">
            <p class="text-xs tracking-[0.3em] text-amber-700 mb-2">{s.area}</p>
            <h3 class="text-lg tracking-wider">{s.name}</h3>
            <p class="text-xs text-stone-400 mt-3">住所・電話番号</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="text-center py-12">
    <a href={base} class="text-xs tracking-[0.3em] text-stone-500 hover:text-amber-700 transition">
      ← BACK TO エドナ屋
    </a>
  </div>
</Layout>
