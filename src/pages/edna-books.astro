---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const allBooks = [
  {
    title: 'CPT Photobook',
    artist: 'FUMI',
    image: `${base}images/books/CPT-photobook.png`,
    description: 'ストリートの皮膚を写すモノクロームの視点。VEGA-Tの言葉と共鳴しながら、場所と身体が交差する瞬間を静かに捉えた眼差し。',
    gallery: [
      `${base}images/books/CPT-photobook/001.jpeg`,
      `${base}images/books/CPT-photobook/002.jpeg`,
      `${base}images/books/CPT-photobook/003.jpeg`,
    ],
    buyUrl: 'https://dolocal.thebase.in/items/38018887',
    pages: 'A4変形 / 100P / モノクロ / 2009',
    slug: 'cpt-photobook',
  },
  {
    title: 'SKID ROW',
    artist: 'FUMI',
    image: `${base}images/books/SKIDROW.png`,
    description: 'ロサンゼルス・ダウンタウンの一街区へ。写真と言葉の両方でSKID ROWの現実に踏み込んだ、FUMIの作家性が最も濃く滲む作品。',
    gallery: [
      `${base}images/books/skidrow/skidrowF_16.jpg`,
      `${base}images/books/skidrow/skidrowF_29.jpg`,
      `${base}images/books/skidrow/skidrowF_73.jpg`,
      `${base}images/books/skidrow/skidrowF_75.jpg`,
      `${base}images/books/skidrow/skidrowF_82.jpg`,
    ],
    buyUrl: 'https://dolocal.thebase.in/items/74795109',
    pages: 'A4/94P / 2023',
    slug: 'skidrow',
  },
  {
    title: 'Super Silent',
    artist: 'FUMI',
    image: `${base}images/books/SuperSilent.jpg`,
    description: '音のない場所を巡る旅。都市の隙間に潜む沈黙を追い、静寂そのものを被写体にした108ページ。FUMIの最大ボリューム作にして最も内省的な一冊。',
    gallery: [
      `${base}images/books/SuperSilent/SuperSilent0702-2.jpg`,
      `${base}images/books/SuperSilent/SuperSilent0702-7.jpg`,
      `${base}images/books/SuperSilent/SuperSilent0702-49.jpg`,
      `${base}images/books/SuperSilent/SuperSilent0702-90.jpg`,
      `${base}images/books/SuperSilent/SuperSilent0702-108.jpg`,
    ],
    buyUrl: '',
    pages: 'A4/108P / 2025',
    slug: 'super-silent',
  },
  {
    title: 'Dear Style Masters,',
    artist: 'Pero Hayashi',
    image: `${base}images/books/dear-style-masters.png`,
    description: 'スタイルを持つすべての人へ宛てた手紙。サーフカルチャーを巡るロードムービーのような、静かで親密な旅の記録。',
    gallery: [
      `${base}images/books/dear-style-masters/1.png`,
      `${base}images/books/dear-style-masters/2.png`,
      `${base}images/books/dear-style-masters/3.png`,
      `${base}images/books/dear-style-masters/4.png`,
      `${base}images/books/dear-style-masters/5.png`,
      `${base}images/books/dear-style-masters/6.png`,
      `${base}images/books/dear-style-masters/7.png`,
      `${base}images/books/dear-style-masters/8.png`,
      `${base}images/books/dear-style-masters/9.png`,
      `${base}images/books/dear-style-masters/10.png`,
      `${base}images/books/dear-style-masters/11.png`,
      `${base}images/books/dear-style-masters/12.png`,
      `${base}images/books/dear-style-masters/13.png`,
    ],
    buyUrl: 'https://ednabooks.base.shop/items/146121330',
    pages: 'A4 / 144P / 2025.10',
    slug: 'dear-style-masters',
  },
  {
    title: "To Leave Is to Return <br /> -Entre Cataluña y Euskadi",
    artist: 'KEIZO OKADA',
    image: `${base}images/books/EntreCataluna_y_Euskadi.jpg`,
    description: 'カタルーニャからバスク地方へ。異なる言語と文化が交差するスペインの風景を、静かな視線で切り取ったドキュメンタリー写真集。',
    gallery: [
      `${base}images/books/EntreCataluna_y_Euskadi/001.jpg`,
      `${base}images/books/EntreCataluna_y_Euskadi/002.jpg`,
      `${base}images/books/EntreCataluna_y_Euskadi/003.jpg`,
      `${base}images/books/EntreCataluna_y_Euskadi/004.jpg`,
      `${base}images/books/EntreCataluna_y_Euskadi/005.jpg`,
    ],
    buyUrl: 'https://ednabooks.base.shop/items/146121587',
    pages: 'A4 / 56P / 2025.10',
    slug: 'entre-cataluna-euskadi',
  },
  {
    title: "To Leave Is to Return <br /> -At The Water's Edge",
    artist: 'KEIZO OKADA',
    image: `${base}images/books/ToLeaveIsToReturn_AtTheWater'sEdge.jpg`,
    description: '水辺にたたずむ人と風景。波打ち際、川沿い、港のほとりなど、水と人間の境界に宿る静けさを丁寧に拾い集めた、シリーズ最大のボリューム。',
    gallery: [
      `${base}images/books/ToLeaveIsToReturn_AtTheWater'sEdge/001.jpg`,
      `${base}images/books/ToLeaveIsToReturn_AtTheWater'sEdge/002.jpg`,
      `${base}images/books/ToLeaveIsToReturn_AtTheWater'sEdge/003.jpg`,
      `${base}images/books/ToLeaveIsToReturn_AtTheWater'sEdge/004.jpg`,
      `${base}images/books/ToLeaveIsToReturn_AtTheWater'sEdge/005.jpg`,
      `${base}images/books/ToLeaveIsToReturn_AtTheWater'sEdge/006.jpg`,
    ],
    buyUrl: 'https://ednabooks.base.shop/items/146124165',
    digitalEditionUrl: 'https://ednabooks.base.shop/items/146598968',
    pages: 'B5 / 84P / 2026.05',
    slug: 'water-edge',
  },
  {
    title: 'To Leave Is to Return <br /> -Saigon Red,Phu Quoc Blue',
    artist: 'KEIZO OKADA',
    image: `${base}images/books/ToLeaveIsToReturn_sigonPhuQuoc.jpg`,
    description: '変わりゆくベトナムのホーチミンとフーコック島。それぞれの場所が持つ独自のカラーを追いかけながら、目覚ましい開発の最中にある2026年を記録した一冊。',
    gallery: [
      `${base}images/books/ToLeaveIsToReturn_sigonPhuQuoc/A7400789.jpg`,
      `${base}images/books/ToLeaveIsToReturn_sigonPhuQuoc/A7401131.jpg`,
      `${base}images/books/ToLeaveIsToReturn_sigonPhuQuoc/A7402744.jpg`,
      `${base}images/books/ToLeaveIsToReturn_sigonPhuQuoc/A7403564.jpg`,
      `${base}images/books/ToLeaveIsToReturn_sigonPhuQuoc/A7405661.jpg`,
      `${base}images/books/ToLeaveIsToReturn_sigonPhuQuoc/A7406414.jpg`,
    ],
    buyUrl: 'https://ednabooks.base.shop/items/146124266',
    digitalEditionUrl: 'https://ednabooks.base.shop/items/146560283',
    pages: 'B5 / 54P / 2026.05',
    slug: 'saigon-phuquoc',
  },
];

// Group books by artist
const booksByArtist = allBooks.reduce((acc, book) => {
  const artist = book.artist;
  if (!acc[artist]) {
    acc[artist] = [];
  }
  acc[artist].push(book);
  return acc;
}, {} as Record<string, typeof allBooks>);

// Sort artists alphabetically
const sortedArtists = Object.keys(booksByArtist).sort();
---

<Layout title="EDNA BOOKS | エドナ屋" description="EDNA BOOKS — アートブック">
  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden -mt-16 pt-16">
    <div class="absolute inset-0">
      <img
        src={`${base}images/heroes/ednabooks.jpg`}
        alt="EDNA BOOKS"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-stone-950/65"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-rose-300 mb-6">Art books</p>
      <h1 class="mb-6 flex justify-center">
        <img
          src={`${base}images/logo/ednabooks_logo.svg`}
          alt="EDNA BOOKS"
          class="h-40 md:h-50 w-auto"
          alt="EDNA BOOKS"
        />
      </h1>
    </div>
  </section>

  <!-- About -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="max-w-3xl mx-auto text-left md:text-center mb-8">
      <!-- <p class="text-xs tracking-[0.4em] text-rose-400 mb-4">ABOUT</p> -->
      <h2 class="text-3xl font-light tracking-wider text-rose-400 mb-12 text-center">ABOUT</h2>
      <p class="text-stone-400 leading-loose">
        ページの中に広がる、もうひとつの世界。<br />
        国内外のアーティストによるアートブックを集めた専門店です。<br />
        写真集、画集、デザイン集 — 紙の手触りと共に、作品の世界へ誘います。
      </p>
    </div>
  </section>

  <!-- Featured Books -->
  <section class="py-24 px-6 bg-black">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-light tracking-wider text-rose-400">PHOTOBOOKS</h2>
      </div>

      {sortedArtists.map((artist, artistIndex) => {
        const artistLinks = {
          'FUMI': 'http://cptcpt.jp/',
          'Pero Hayashi': 'https://www.perophoto.com/',
          'KEIZO OKADA': '/edna-books/artist/keizo-okada',
        };
        const href = artistLinks[artist as keyof typeof artistLinks] || '#';
        const displayName = artist === 'Pero Hayashi' ? 'PERO HAYASHI' : artist;

        return (
        <div>
          <div class="mb-12">
            <a href={href} class="group inline-flex items-center gap-2 mb-2" target="_blank" rel="noopener noreferrer">
              <h3 class="text-lg font-light tracking-wider text-rose-300
                group-hover:underline group-hover:text-rose-200
                transition-colors cursor-pointer">
                {displayName}
              </h3>
              <svg class="w-4 h-4 text-rose-300 group-hover:text-rose-200 transition-colors shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M13.5 6H5.82C4.4 6 3 7.37 3 8.82V19c0 1.4 1.37 2.5 2.82 2.5h10.44c1.4 0 2.74-1.1 2.74-2.5v-7.67h-2v7.67H5.82V8.82h7.68V6z"/>
                <path d="M21 3v6.5h-1.5V6.12L11.88 14.25l-1.06-1.06L18.44 5h-3.38V3z"/>
              </svg>
            </a>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
              {booksByArtist[artist].map((book) => (
                <div class="flex flex-col h-full">
                  {/* Cover Image */}
                  <div
                    class="group relative bg-stone-900 aspect-3/4 overflow-hidden border border-stone-800 hover:border-rose-400 transition mb-3 cursor-pointer"
                    data-gallery={book.gallery ? JSON.stringify(book.gallery) : null}
                    onclick={book.gallery ? "openLightbox(this)" : null}
                  >
                    {book.image ? (
                      <img
                        src={book.image}
                        alt={book.title}
                        class="w-full h-full object-cover group-hover:opacity-80 transition-opacity"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center">
                        <span class="text-xs tracking-[0.3em] text-stone-600">BOOK</span>
                      </div>
                    )}
                    {/* Hover Overlay */}
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/30">
                      <span class="px-3 py-1.5 bg-black/80 text-xs tracking-wider text-rose-300 rounded">Click to preview</span>
                    </div>
                  </div>

                  {/* Title */}
                  <p class="text-sm md:text-base tracking-wider text-stone-300 mb-2" set:html={book.title} />

                  {/* Spec */}
                  {book.pages && <p class="text-xs text-stone-600 mb-3">{book.pages}</p>}

                  {/* Description */}
                  <p class="text-sm text-stone-500 mb-4 grow line-clamp-3">
                    {book.description}
                  </p>

                  {/* Action Buttons */}
                  <div class="flex flex-col gap-2">
                    <div class="flex gap-2">
                      {book.buyUrl ? (
                        <a
                          href={book.buyUrl}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="flex-1 flex items-center justify-center px-3 py-1.5 text-xs tracking-[0.2em] border border-rose-400 text-rose-400 hover:bg-rose-400 hover:text-black transition min-h-11.5"
                          onclick="event.stopPropagation()"
                        >
                          BUY
                        </a>
                      ) : (
                        <span
                          class="flex-1 flex items-center justify-center px-3 py-1.5 text-xs tracking-[0.2em] border border-stone-700 text-stone-600 cursor-default min-h-11.5"
                          onclick="event.stopPropagation()"
                        >
                          BUY
                        </span>
                      )}
                      {book.gallery && (
                        <button
                          class="flex-1 px-3 py-1.5 text-xs tracking-[0.2em] border border-rose-400 bg-rose-400 text-black hover:bg-transparent hover:text-rose-400 transition text-center flex items-center justify-center gap-2 min-h-11.5"
                          data-gallery={JSON.stringify(book.gallery)}
                          onclick="event.stopPropagation(); openLightbox(this)"
                        >
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
                          </svg>
                          PREVIEW
                        </button>
                      )}
                    </div>
                    {book.digitalEditionUrl ? (
                      <a
                        href={book.digitalEditionUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="w-full px-3 py-1.5 text-xs tracking-[0.2em] border border-rose-400 text-rose-400 hover:bg-rose-400 hover:text-black transition flex items-center justify-center gap-2 min-h-11.5"
                        onclick="event.stopPropagation()"
                      >
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                        </svg>
                        BUY DIGITAL (PDF)
                      </a>
                    ) : (
                      <div class="w-full px-3 py-1.5 border border-transparent min-h-11.5"></div>
                    )}
                  </div>
                </div>
              ))}
            </div>
            {artistIndex < sortedArtists.length - 1 && <hr class="border-stone-800 mb-12" />}
          </div>
        </div>
        );
      })}
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lb" class="fixed inset-0 z-50 hidden flex-col items-center justify-center bg-black/90" role="dialog" aria-modal="true">
    <!-- 左右の判定エリア（縦全体） -->
    <button id="lb-prev" class="absolute left-0 top-0 h-full w-[15%] flex items-center justify-start pl-4 text-white/50 hover:text-white text-5xl transition-colors z-10" aria-label="前へ">‹</button>
    <button id="lb-next" class="absolute right-0 top-0 h-full w-[15%] flex items-center justify-end pr-4 text-white/50 hover:text-white text-5xl transition-colors z-10" aria-label="次へ">›</button>
    <!-- 画像 -->
    <img id="lb-img" src="" alt="" class="max-h-[85vh] max-w-[70vw] object-contain select-none" />
    <p id="lb-counter" class="mt-4 text-xs tracking-widest text-stone-500"></p>
    <button id="lb-close" class="absolute top-6 right-6 text-white text-3xl leading-none hover:text-rose-300 transition-colors z-20" aria-label="閉じる">✕</button>
  </div>

  <script>
    let photos: string[] = [];
    let current = 0;
    let touchStartX = 0;
    let touchStartY = 0;

    const lb     = document.getElementById('lb')!;
    const lbImg  = document.getElementById('lb-img') as HTMLImageElement;
    const lbCnt  = document.getElementById('lb-counter')!;

    function showPhoto() {
      lbImg.src = photos[current];
      lbCnt.textContent = `${current + 1} / ${photos.length}`;
    }

    function openLightbox(el: HTMLElement) {
      photos = JSON.parse(el.dataset.gallery || '[]');
      current = 0;
      showPhoto();
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      lbImg.src = '';
      document.body.style.overflow = '';
    }

    function prevPhoto() { current = (current - 1 + photos.length) % photos.length; showPhoto(); }
    function nextPhoto() { current = (current + 1) % photos.length; showPhoto(); }

    document.getElementById('lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); prevPhoto(); });
    document.getElementById('lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); nextPhoto(); });
    document.getElementById('lb-close')!.addEventListener('click', closeLightbox);

    lb.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    lb.addEventListener('touchmove', (e) => {
      const dx = Math.abs(e.touches[0].clientX - touchStartX);
      const dy = Math.abs(e.touches[0].clientY - touchStartY);
      if (dx > dy) e.preventDefault();
    }, { passive: false });

    lb.addEventListener('touchend', (e) => {
      const dx = touchStartX - e.changedTouches[0].clientX;
      const dy = Math.abs(e.changedTouches[0].clientY - touchStartY);
      if (Math.abs(dx) > 40 && Math.abs(dx) > dy) {
        dx > 0 ? nextPhoto() : prevPhoto();
      }
    }, { passive: true });

    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('flex')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') prevPhoto();
      if (e.key === 'ArrowRight') nextPhoto();
    });

    (window as any).openLightbox = openLightbox;
  </script>

  <!-- Categories -->
  <!--section class="py-24 px-6 bg-stone-950">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-rose-400 mb-4">CATEGORIES</p>
        <h2 class="text-3xl font-light tracking-wider text-white">取り扱いジャンル</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        {['PHOTOGRAPHY', 'ILLUSTRATION', 'DESIGN', 'PAINTING'].map((c) => (
          <div class="border border-stone-800 py-8 hover:border-rose-400 transition">
            <p class="text-xs tracking-[0.3em] text-rose-300">{c}</p>
          </div>
        ))}
      </div>
    </div>
  </section-->

  <div class="text-center py-3 bg-stone-950">
    <a href={base} class="text-xs tracking-[0.3em] text-stone-500 hover:text-rose-400 transition">
      ← BACK TO エドナ屋
    </a>
  </div>
</Layout>
