---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const galleryImages = [
  { src: `${base}/images/planet-foto-labo/pero_001.jpg`, alt: "pero_001", caption: "アクリルフォトパネル / Pero" },
  { src: `${base}/images/planet-foto-labo/pero_002.jpg`, alt: "pero_002", caption: "アクリルフォトパネル / Pero" },
  { src: `${base}/images/planet-foto-labo/pero_003.jpg`, alt: "pero_003", caption: "アクリルフォトパネル / Pero" },
  { src: `${base}/images/planet-foto-labo/pero_004.jpg`, alt: "pero_004", caption: "アクリルフォトパネル / Pero" },
  { src: `${base}/images/planet-foto-labo/pero_005.jpg`, alt: "pero_005", caption: "アクリルフォトパネル / Pero" },
  { src: `${base}/images/planet-foto-labo/pero_005.jpg`, alt: "pero_005", caption: "アクリルフォトパネル / Pero" },
  { src: `${base}/images/planet-foto-labo/pero_005.jpg`, alt: "pero_005", caption: "アクリルフォトパネル / Pero" },
  { src: `${base}/images/planet-foto-labo/pero_005.jpg`, alt: "pero_005", caption: "アクリルフォトパネル / Pero" },
  { src: `${base}/images/planet-foto-labo/pero_005.jpg`, alt: "pero_005", caption: "アクリルフォトパネル / Pero" },
];
---

<Layout title="PLANET FOTO LABO | エドナ屋" description="PLANET FOTO LABO — 写真家のアトリエ。">
  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden -mt-16 pt-16">
    <div class="absolute inset-0">
      <img
        src={`${base}/images/heroes/planet-foto-labo03.jpg`}
        alt="PLANET FOTO LABO"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-stone-950/65"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-sky-300 mb-6">EDNAYA / 03</p>
      <h1 class="mb-6 flex justify-center">
        <img
          src={`${base}/images/logo/pfl-white.png`}
          alt="PLANET FOTO LABO"
          class="h-20 md:h-28 w-auto"
          alt="planet-foto-labo"
        />
      </h1>
      <p class="text-sm tracking-[0.3em] text-stone-300">PHOTOGRAPHER'S ATELIER</p>
    </div>
  </section>

  <!-- About -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs tracking-[0.4em] text-sky-400 mb-4">ABOUT</p>
      <h2 class="text-3xl font-light tracking-wider text-white mb-12">アトリエについて</h2>
      <p class="text-stone-400 leading-loose">
        写真家のアトリエ「PLANET FOTO LABO」。<br />
        光と時間を捉えた一枚の物語を、ここから世界へ。<br />
        作品制作・展示・撮影依頼を承っております。
      </p>
    </div>
  </section>

  <!-- Artists -->
  <section class="py-24 px-6 bg-black">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-sky-400 mb-4">ARTISTS</p>
        <h2 class="text-3xl font-light tracking-wider text-white">アーティスト</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            name: 'Pero',
            nameJa: 'アーティスト 1',
            role: 'PHOTOGRAPHER',
            bio: 'プロフィールや略歴をここに記載します。代表作・受賞歴・作風など、このアーティストを表現する文章を入れてください。',
            url: 'https://www.perophoto.com/',
            urlLabel: 'PORTFOLIO',
            image: 'pero.jpg',
          },
          {
            name: 'Fumi Photo',
            nameJa: 'アーティスト 2',
            role: 'PHOTOGRAPHER',
            bio: 'プロフィールや略歴をここに記載します。代表作・受賞歴・作風など、このアーティストを表現する文章を入れてください。',
            url: 'http://cptcpt.jp/',
            urlLabel: 'PORTFOLIO',
            image: 'fumi.Jpg',
          },
        ].map((a) => (
          <a
            href={a.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block border border-stone-800 hover:border-sky-400 transition overflow-hidden"
          >
            <div class="aspect-[4/5] overflow-hidden bg-stone-900">
              {a.image ? (
                <img
                  src={`${base}/images/artists/${a.image}`}
                  alt={a.name}
                  class="w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-xs tracking-[0.3em] text-stone-700">PORTRAIT</span>
                </div>
              )}
            </div>
            <div class="p-8">
              <p class="text-xs tracking-[0.3em] text-sky-400 mb-3">{a.role}</p>
              <h3 class="text-2xl font-light tracking-widest text-white mb-1">{a.name}</h3>
              <p class="text-xs text-stone-500 tracking-wider mb-6">{a.nameJa}</p>
              <p class="text-sm text-stone-400 leading-loose mb-6">{a.bio}</p>
              <span class="inline-flex items-center gap-2 text-xs tracking-[0.3em] text-sky-300 group-hover:text-sky-200 transition">
                {a.urlLabel} ↗
                <span class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-sky-400 mb-4">GALLERY</p>
        <h2 class="text-3xl font-light tracking-wider text-white">作品ギャラリー</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
        {galleryImages.map((img) => (
          <div>
            <a
              href={img.src}
              class="glightbox group relative bg-stone-900 aspect-[4/5] overflow-hidden block"
              data-gallery="gallery"
            >
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </a>
            <p class="mt-2 mb-6 text-xs tracking-[0.2em] text-stone-400 text-right">{img.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-24 px-6 bg-black">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-sky-400 mb-4">SERVICES</p>
        <h2 class="text-3xl font-light tracking-wider text-white">サービス</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { name: 'PORTRAIT', desc: 'ポートレート撮影。人の魅力を引き出す一枚を。' },
          { name: 'COMMERCIAL', desc: '商品・広告撮影。ブランドの世界観を写真で。' },
          { name: 'EXHIBITION', desc: '作品展示・販売。アトリエ作品をご紹介します。' },
        ].map((s) => (
          <div class="text-center">
            <p class="text-xs tracking-[0.3em] text-sky-400 mb-4">{s.name}</p>
            <p class="text-sm text-stone-400 leading-loose">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="text-center py-12 bg-stone-950">
    <a href={base} class="text-xs tracking-[0.3em] text-stone-500 hover:text-sky-400 transition">
      ← BACK TO エドナ屋
    </a>
  </div>
</Layout>

<script>
  import GLightbox from 'glightbox';
  import 'glightbox/dist/css/glightbox.min.css';

  GLightbox({ selector: '.glightbox' });
</script>
