---

<Layout title="PLANET FOTO LABO | エドナ屋" description="PLANET FOTO LABO — 写真家のアトリエ。">
  <!-- Hero -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden -mt-16 pt-16">
    <div class="absolute inset-0">
      <img
        src={`${base}/images/heroes/planet-foto-labo03.jpg`}
        alt="PLANET FOTO LABO"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-stone-950/65"></div>
    </div>
    <div class="relative z-10 text-center px-6">
      <p class="text-xs tracking-[0.5em] text-sky-300 mb-6">PHOTOGRAPHER'S ATELIER</p>
      <h1 class="mb-6 flex justify-center">
        <img
          src={`${base}/images/logo/pfl-white.png`}
          alt="PLANET FOTO LABO"
          class="h-30 md:h-50 w-auto"
          alt="planet-foto-labo"
        />
      </h1>
      <!-- <p class="text-sm tracking-[0.3em] text-stone-300">PHOTOGRAPHER'S ATELIER</p> -->
    </div>
  </section>

  <!-- About -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="max-w-3xl mx-auto text-center">
      <!-- <p class="text-xs tracking-[0.4em] text-sky-400 mb-4">ABOUT</p> -->
      <h2 class="text-3xl font-light tracking-wider text-sky-400 mb-12">ABOUT</h2>
      <p class="text-stone-400 leading-loose">
        辻堂のBAR ”COAST TAVERN”でのバイト時代に出逢った２人が20年の年月を得て互いに写真家として活動をし、シェイパーの榎本信介の主宰する藤沢本町エドナ屋のFACTORYに集い、日々制作活動に楽しく勤しんでいます。
      </p>
    </div>
  </section>

  <!-- Artists -->
  <section class="py-24 px-6 bg-black">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <!-- <p class="text-xs tracking-[0.4em] text-sky-400 mb-4">ARTISTS</p> -->
        <h2 class="text-3xl font-light tracking-wider text-sky-400">ARTISTS</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            name: 'Pero',
            role: 'PHOTOGRAPHER',
            bio: '1972生まれ 鵠沼在住<br />カメラ好きの父親に導かれる様にカメラをいじり始める。<br />東京工芸大芸術学部写真学科<br />卒業Movie & Still Camereman 芝田満之氏に出逢い作品を観て頂き運良くアシスタントとして学ぶ機会を得て撮影や人生のイロハを学び、現在に至る。',
            url: 'https://www.perophoto.com/',
            instagram: 'https://www.instagram.com/pero_884/',
            image: 'pero.jpg',
          },
          {
            name: 'Fumi Photo',
            role: 'PHOTOGRAPHER',
            bio: '1998年渡米、LAでの5年半の後2004年帰国。<br />ヒップホップ、レゲエを中心に写真を撮らせて頂き、最近は木が喋ってると思い始めてから自然にドハマってます。',
            url: 'http://cptcpt.jp/',
            instagram: 'https://www.instagram.com/fumiphoto/',
            image: 'fumi002.jpg',
          },
        ].map((a) => (
          <div class="border border-stone-800 overflow-hidden">
            <div class="aspect-4/5 overflow-hidden bg-stone-900">
              {a.image ? (
                <img
                  src={`${base}/images/artists/${a.image}`}
                  alt={a.name}
                  class="w-full h-full object-cover opacity-90"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-xs tracking-[0.3em] text-stone-700">PORTRAIT</span>
                </div>
              )}
            </div>
            <div class="p-8">
              <p class="text-xs tracking-[0.3em] text-sky-400 mb-3">{a.role}</p>
              <h3 class="text-2xl font-light tracking-widest text-white mb-1">{a.name}</h3>
              <p class="text-xs text-stone-500 tracking-wider mb-6">{a.nameJa}</p>
              <p class="text-sm text-stone-400 leading-relaxed mb-6" set:html={a.bio} />
              <div class="flex items-center gap-6">
                <a
                  href={a.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-xs tracking-[0.3em] text-sky-300 hover:text-sky-200 transition"
                >
                  PORTFOLIO ↗
                </a>
                {a.instagram && (
                  <a
                    href={a.instagram}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-stone-400 hover:text-sky-300 transition"
                    aria-label="Instagram"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                      <circle cx="12" cy="12" r="4"/>
                      <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
                    </svg>
                    <span class="text-xs tracking-[0.2em]">INSTAGRAM</span>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="py-24 px-6 bg-stone-950">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <!-- <p class="text-xs tracking-[0.4em] text-sky-400 mb-4">GALLERY</p> -->
        <h2 class="text-3xl font-light tracking-wider text-sky-400 mb-12">GALLERY</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Pero -->
        <div>
          <h3 class="text-lg font-light tracking-[0.2em] text-white mb-6 border-b border-stone-800 pb-3">Pero</h3>
          <div
            class="grid grid-cols-1 md:grid-cols-2 gap-2"
            data-gallery={JSON.stringify(peroImages)}
          >
            {peroImages.map((src, idx) => (
              <div
                class="bg-stone-900 aspect-4/5 overflow-hidden cursor-pointer group"
                onclick={`openLightbox(this.parentElement, ${idx})`}
              >
                <img
                  src={src}
                  alt=""
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
          <!-- <p class="mt-4 text-xs text-stone-400 text-right">アクリルフォトパネル / 900mm x 600mm ¥88,000 | 600mm x 300mm ¥44,000</p> -->
        </div>

        <!-- Fumi Photo -->
        <div>
          <h3 class="text-lg font-light tracking-[0.2em] text-white mb-6 border-b border-stone-800 pb-3">Fumi Photo</h3>
          {fumiImages.length > 0 ? (
            <div
              class="grid grid-cols-1 md:grid-cols-2 gap-2"
              data-gallery={JSON.stringify(fumiImages)}
            >
              {fumiImages.map((src, idx) => (
                <div
                  class="bg-stone-900 aspect-4/5 overflow-hidden cursor-pointer group"
                  onclick={`openLightbox(this.parentElement, ${idx})`}
                >
                  <img
                    src={src}
                    alt=""
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          ) : (
            <div class="bg-stone-900 aspect-4/5 flex items-center justify-center border border-stone-800">
              <span class="text-xs tracking-[0.3em] text-stone-600">COMING SOON</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <!--section class="py-24 px-6 bg-black">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.4em] text-sky-400 mb-4">SERVICES</p>
        <h2 class="text-3xl font-light tracking-wider text-white">サービス</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { name: 'PORTRAIT', desc: 'ポートレート撮影。人の魅力を引き出す一枚を。' },
          { name: 'COMMERCIAL', desc: '商品・広告撮影。ブランドの世界観を写真で。' },
          { name: 'EXHIBITION', desc: '作品展示・販売。アトリエ作品をご紹介します。' },
        ].map((s) => (
          <div class="text-center">
            <p class="text-xs tracking-[0.3em] text-sky-400 mb-4">{s.name}</p>
            <p class="text-sm text-stone-400 leading-loose">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section-->

  <div class="text-center py-12 bg-stone-950">
    <a href={base} class="text-xs tracking-[0.3em] text-stone-500 hover:text-sky-400 transition">
      ← BACK TO エドナ屋
    </a>
  </div>
</Layout>

<!-- Lightbox -->
<div id="lb" class="fixed inset-0 z-50 hidden flex-col items-center justify-center bg-black/90" role="dialog" aria-modal="true">
  <button id="lb-prev" class="absolute left-0 top-0 h-full w-[15%] flex items-center justify-start pl-4 text-white/50 hover:text-white text-5xl transition-colors z-10" aria-label="前へ">‹</button>
  <button id="lb-next" class="absolute right-0 top-0 h-full w-[15%] flex items-center justify-end pr-4 text-white/50 hover:text-white text-5xl transition-colors z-10" aria-label="次へ">›</button>
  <img id="lb-img" src="" alt="" class="max-h-[85vh] max-w-[70vw] object-contain select-none" />
  <p id="lb-counter" class="mt-4 text-xs tracking-widest text-stone-500"></p>
  <button id="lb-close" class="absolute top-6 right-6 text-white text-3xl leading-none hover:text-sky-300 transition-colors z-20" aria-label="閉じる">✕</button>
</div>

<script>
  let photos: string[] = [];
  let current = 0;
  let touchStartX = 0;
  let touchStartY = 0;

  const lb    = document.getElementById('lb')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCnt = document.getElementById('lb-counter')!;

  function showPhoto() {
    lbImg.src = photos[current];
    lbCnt.textContent = `${current + 1} / ${photos.length}`;
  }

  function openLightbox(gridEl: HTMLElement, index: number) {
    photos = JSON.parse(gridEl.dataset.gallery || '[]');
    current = index;
    showPhoto();
    lb.classList.remove('hidden');
    lb.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lb.classList.add('hidden');
    lb.classList.remove('flex');
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  function prevPhoto() { current = (current - 1 + photos.length) % photos.length; showPhoto(); }
  function nextPhoto() { current = (current + 1) % photos.length; showPhoto(); }

  document.getElementById('lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); prevPhoto(); });
  document.getElementById('lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); nextPhoto(); });
  document.getElementById('lb-close')!.addEventListener('click', closeLightbox);

  lb.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; touchStartY = e.touches[0].clientY; }, { passive: true });
  lb.addEventListener('touchmove', (e) => { const dx = Math.abs(e.touches[0].clientX - touchStartX); const dy = Math.abs(e.touches[0].clientY - touchStartY); if (dx > dy) e.preventDefault(); }, { passive: false });
  lb.addEventListener('touchend', (e) => { const dx = touchStartX - e.changedTouches[0].clientX; const dy = Math.abs(e.changedTouches[0].clientY - touchStartY); if (Math.abs(dx) > 40 && Math.abs(dx) > dy) { dx > 0 ? nextPhoto() : prevPhoto(); } }, { passive: true });

  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('flex')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') prevPhoto();
    if (e.key === 'ArrowRight') nextPhoto();
  });

  (window as any).openLightbox = openLightbox;
</script>
